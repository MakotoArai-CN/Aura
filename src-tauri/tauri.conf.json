{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aura",
  "version": "1.0.0",
  "identifier": "com.makotoarai.aura",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Aura",
        "width": 1000,
        "height": 670,
        "minWidth": 600,
        "minHeight": 300,
        "decorations": false,
        "transparent": true,
        "center": true
      },
      {
        "label": "float",
        "title": "Aura Lyrics",
        "url": "float.html",
        "width": 1000,
        "height": 70,
        "minWidth": 640,
        "minHeight": 60,
        "maxWidth": 1920,
        "maxHeight": 220,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      },
      {
        "label": "login",
        "title": "Aura 登录",
        "url": "login.html",
        "width": 985,
        "height": 700,
        "minWidth": 760,
        "minHeight": 560,
        "decorations": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Music",
    "android": {
      "minSdkVersion": 24
    },
    "iOS": {
      "developmentTeam": ""
    },
    "windows": {
      "wix": null,
      "nsis": {
        "displayLanguageSelector": true
      }
    }
  }
}
