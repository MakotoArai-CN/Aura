{
  "$schema": "https://schemas.tauri.app/config/2/capability",
  "identifier": "mobile",
  "description": "Listen1 mobile capabilities",
  "windows": ["main"],
  "platforms": ["android", "iOS"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "shell:allow-open",
    "dialog:allow-open",
    "fs:allow-read-file"
  ]
}
